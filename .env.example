# Stripe Configuration (Find these in Stripe Dashboard > Developers)
# Secret Key (sk_test_...) - Used by Edge Functions/Server
STRIPE_SECRET_KEY=
# Webhook Signing Secret (whsec_...) - Found after creating a webhook endpoint
STRIPE_WEBHOOK_SECRET=
# Publishable Key (pk_test_...) - Used by Frontend (if needed)
VITE_STRIPE_PUBLISHABLE_KEY=
# Price IDs for your products (Found in Stripe Dashboard > Product Catalog)
VITE_STRIPE_PRICE_ID_PLUS=
VITE_STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID=

# App Configuration
# The base URL of your application (used for Stripe redirects)
APP_URL=https://ais-dev-jh4dlv452krq2aij2uuv2f-65109628859.us-east1.run.app

# Supabase Configuration (Find these in Supabase Dashboard > Settings > API)
# Project URL
SUPABASE_URL=
# Public Anon Key (Safe for frontend)
VITE_SUPABASE_ANON_KEY=
# Service Role Key (SECRET: Only for server/Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=

# AI Configuration
# Gemini API Key (Found in Google AI Studio)
GEMINI_API_KEY=
